# Example systemd unit for shared preview WS runtime.
# Copy to /etc/systemd/system/ws-server-preview.service and adjust paths/user.
[Unit]
Description=Arcade WS Preview Server
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/arcade-ws-preview/ws-server
EnvironmentFile=/opt/arcade-ws-preview/.env.preview
ExecStart=/usr/bin/node server.mjs
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
